# ── Surrogate OS API — Environment Variables ─────────────────────────

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://surrogate:surrogate_dev@localhost:5432/surrogate_os

# Authentication (JWT)
JWT_SECRET=surrogate-dev-secret-change-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Observability (OpenTelemetry)
OTEL_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

# LLM (Anthropic Claude API)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
